/**
 * ProfileScreen Tests
 *
 * Tests for ProfileScreen component covering:
 * - Rendering with authenticated user
 * - User information display (name, email, avatar)
 * - Edit mode functionality
 * - Profile update operations
 * - Navigation to settings
 * - Loading states
 * - Error handling
 */

import React from 'react'
import { describe, it, expect, vi, beforeEach } from 'vitest'
import { screen, fireEvent, waitFor } from '@testing-library/react-native'
import { renderWithProviders } from '../../__tests__/utils/render-with-providers'
import { createMockProfile } from '../../__tests__/utils/factories'
import { ProfileScreen } from '../ProfileScreen'

// ============================================================================
// MOCKS
// ============================================================================

// Mock navigation
const mockNavigate = vi.fn()
const mockGoBack = vi.fn()

// Override the global navigation mock for this test
vi.mock('@react-navigation/native', () => ({
  useNavigation: () => ({
    navigate: mockNavigate,
    goBack: mockGoBack,
    replace: vi.fn(),
    reset: vi.fn(),
    setOptions: vi.fn(),
    addListener: vi.fn(() => () => {}),
  }),
  useRoute: () => ({ params: {} }),
  useFocusEffect: (callback: () => void) => {
    const cleanup = callback()
    return cleanup
  },
  useIsFocused: () => true,
  NavigationContainer: ({ children }: { children: React.ReactNode }) => children,
  createNavigationContainerRef: () => ({ current: null }),
}))

// Mock useAchievements hook
const mockUseAchievements = vi.fn()
vi.mock('../../hooks/useAchievements', () => ({
  useAchievements: () => mockUseAchievements(),
}))

// Mock useTrustLevel hook
const mockUseTrustLevel = vi.fn()
vi.mock('../../hooks/useTrustLevel', () => ({
  useTrustLevel: () => mockUseTrustLevel(),
}))

// Mock expo-linear-gradient (used in ProfileScreen)
vi.mock('expo-linear-gradient', () => ({
  LinearGradient: vi.fn(() => null),
}))

// Mock react-native-safe-area-context
vi.mock('react-native-safe-area-context', () => ({
  useSafeAreaInsets: () => ({ top: 0, bottom: 0, left: 0, right: 0 }),
  SafeAreaProvider: ({ children }: { children: React.ReactNode }) => children,
  SafeAreaView: 'SafeAreaView',
  EdgeInsets: {},
}))

// Mock react-native-bitmoji
vi.mock('react-native-bitmoji', () => ({
  Avatar: vi.fn(() => null),
  loadCurrentAvatar: vi.fn().mockResolvedValue({
    id: 'current-avatar',
    config: { metadata: { version: 2 }, features: {}, colors: {} },
    createdAt: Date.now(),
    updatedAt: Date.now(),
  }),
}))

// Mock ProfilePhotoGallery
vi.mock('../../components/ProfilePhotoGallery', () => ({
  ProfilePhotoGallery: vi.fn(() => null),
}))

// Mock AchievementBadge
vi.mock('../../components/AchievementBadge', () => ({
  AchievementBadge: vi.fn(() => null),
}))

// Mock TrustProgress
vi.mock('../../components/TrustProgress', () => ({
  TrustProgress: vi.fn(() => null),
}))

// Mock FloatingActionButtons
vi.mock('../../components/navigation/FloatingActionButtons', () => ({
  FloatingActionButtons: vi.fn(() => null),
}))

// Mock VerifiedBadge
vi.mock('../../components/VerifiedBadge', () => ({
  VerifiedBadge: vi.fn(() => null),
}))

// Mock VerificationPrompt
vi.mock('../../components/VerificationPrompt', () => ({
  VerificationPrompt: vi.fn(() => null),
}))

// Mock ToastContext
vi.mock('../../contexts/ToastContext', () => ({
  useToast: () => ({
    showToast: vi.fn(),
  }),
  ToastProvider: ({ children }: { children: React.ReactNode }) => children,
}))

// Mock LoadingSpinner
vi.mock('../../components/LoadingSpinner', () => ({
  LoadingSpinner: vi.fn(({ message, fullScreen, testID }: any) => null),
}))

// Mock haptics
vi.mock('../../lib/haptics', () => ({
  successFeedback: vi.fn(),
  errorFeedback: vi.fn(),
}))

// ============================================================================
// TESTS
// ============================================================================

describe('ProfileScreen', () => {
  // ---------------------------------------------------------------------------
  // SETUP
  // ---------------------------------------------------------------------------

  beforeEach(() => {
    vi.clearAllMocks()

    // Default mock implementations
    mockUseAchievements.mockReturnValue({
      earnedAchievements: [],
      totalCount: 10,
      earnedCount: 0,
      loading: false,
    })

    mockUseTrustLevel.mockReturnValue({
      trustLevel: 1,
      trustPoints: 0,
    })
  })

  // ---------------------------------------------------------------------------
  // RENDERING TESTS
  // ---------------------------------------------------------------------------

  it('renders without crashing with authenticated user', () => {
    const profile = createMockProfile({
      display_name: 'John Doe',
    })

    renderWithProviders(<ProfileScreen />, {
      authContext: {
        profile,
        user: {
          id: profile.id,
          email: 'john@example.com',
          aud: 'authenticated',
          role: 'authenticated',
          email_confirmed_at: new Date().toISOString(),
          phone: null,
          confirmed_at: new Date().toISOString(),
          last_sign_in_at: new Date().toISOString(),
          app_metadata: {},
          user_metadata: {},
          identities: [],
          created_at: new Date().toISOString(),
          updated_at: new Date().toISOString(),
        },
        isLoading: false,
      },
    })

    expect(screen.getByTestId('profile-screen')).toBeDefined()
  })

  it('displays loading state when auth is loading', () => {
    renderWithProviders(<ProfileScreen />, {
      authContext: {
        isLoading: true,
        isAuthenticated: false,
        user: null,
        profile: null,
      },
    })

    expect(screen.getByTestId('profile-loading')).toBeDefined()
  })

  // ---------------------------------------------------------------------------
  // USER INFORMATION DISPLAY
  // ---------------------------------------------------------------------------

  it('displays user display name', () => {
    const profile = createMockProfile({
      display_name: 'Jane Smith',
    })

    renderWithProviders(<ProfileScreen />, {
      authContext: {
        profile,
        user: {
          id: profile.id,
          email: 'jane@example.com',
          aud: 'authenticated',
          role: 'authenticated',
          email_confirmed_at: new Date().toISOString(),
          phone: null,
          confirmed_at: new Date().toISOString(),
          last_sign_in_at: new Date().toISOString(),
          app_metadata: {},
          user_metadata: {},
          identities: [],
          created_at: new Date().toISOString(),
          updated_at: new Date().toISOString(),
        },
      },
    })

    expect(screen.getByText('Jane Smith')).toBeDefined()
  })

  it('displays user email', () => {
    const profile = createMockProfile()

    renderWithProviders(<ProfileScreen />, {
      authContext: {
        profile,
        user: {
          id: profile.id,
          email: 'user@test.com',
          aud: 'authenticated',
          role: 'authenticated',
          email_confirmed_at: new Date().toISOString(),
          phone: null,
          confirmed_at: new Date().toISOString(),
          last_sign_in_at: new Date().toISOString(),
          app_metadata: {},
          user_metadata: {},
          identities: [],
          created_at: new Date().toISOString(),
          updated_at: new Date().toISOString(),
        },
      },
    })

    expect(screen.getByText('user@test.com')).toBeDefined()
  })

  it('displays "Not set" when display name is null', () => {
    const profile = createMockProfile({
      display_name: null,
    })

    renderWithProviders(<ProfileScreen />, {
      authContext: {
        profile,
        user: {
          id: profile.id,
          email: 'test@example.com',
          aud: 'authenticated',
          role: 'authenticated',
          email_confirmed_at: new Date().toISOString(),
          phone: null,
          confirmed_at: new Date().toISOString(),
          last_sign_in_at: new Date().toISOString(),
          app_metadata: {},
          user_metadata: {},
          identities: [],
          created_at: new Date().toISOString(),
          updated_at: new Date().toISOString(),
        },
      },
    })

    expect(screen.getByText('Not set')).toBeDefined()
  })

  // ---------------------------------------------------------------------------
  // AVATAR TESTS
  // ---------------------------------------------------------------------------

  it('shows avatar placeholder with first letter of display name', () => {
    const profile = createMockProfile({
      display_name: 'Alice',
    })

    renderWithProviders(<ProfileScreen />, {
      authContext: {
        profile,
        user: {
          id: profile.id,
          email: 'alice@example.com',
          aud: 'authenticated',
          role: 'authenticated',
          email_confirmed_at: new Date().toISOString(),
          phone: null,
          confirmed_at: new Date().toISOString(),
          last_sign_in_at: new Date().toISOString(),
          app_metadata: {},
          user_metadata: {},
          identities: [],
          created_at: new Date().toISOString(),
          updated_at: new Date().toISOString(),
        },
      },
    })

    expect(screen.getByTestId('profile-avatar-placeholder')).toBeDefined()
    expect(screen.getByText('A')).toBeDefined()
  })

  // ---------------------------------------------------------------------------
  // TRUST LEVEL & ACHIEVEMENTS
  // ---------------------------------------------------------------------------

  it('shows trust level section', () => {
    mockUseTrustLevel.mockReturnValue({
      trustLevel: 2,
      trustPoints: 75,
    })

    const profile = createMockProfile()

    renderWithProviders(<ProfileScreen />, {
      authContext: {
        profile,
        user: {
          id: profile.id,
          email: 'test@example.com',
          aud: 'authenticated',
          role: 'authenticated',
          email_confirmed_at: new Date().toISOString(),
          phone: null,
          confirmed_at: new Date().toISOString(),
          last_sign_in_at: new Date().toISOString(),
          app_metadata: {},
          user_metadata: {},
          identities: [],
          created_at: new Date().toISOString(),
          updated_at: new Date().toISOString(),
        },
      },
    })

    expect(screen.getByTestId('profile-trust-progress')).toBeDefined()
    expect(screen.getByText('Trust Level')).toBeDefined()
  })

  it('shows achievements section', () => {
    mockUseAchievements.mockReturnValue({
      earnedAchievements: [
        {
          id: 'achievement-1',
          name: 'First Visit',
          description: 'Visit your first location',
          icon: 'trophy',
          earned: true,
        },
      ],
      totalCount: 10,
      earnedCount: 1,
      loading: false,
    })

    const profile = createMockProfile()

    renderWithProviders(<ProfileScreen />, {
      authContext: {
        profile,
        user: {
          id: profile.id,
          email: 'test@example.com',
          aud: 'authenticated',
          role: 'authenticated',
          email_confirmed_at: new Date().toISOString(),
          phone: null,
          confirmed_at: new Date().toISOString(),
          last_sign_in_at: new Date().toISOString(),
          app_metadata: {},
          user_metadata: {},
          identities: [],
          created_at: new Date().toISOString(),
          updated_at: new Date().toISOString(),
        },
      },
    })

    expect(screen.getByText('Achievements')).toBeDefined()
    expect(screen.getByText('1/10 Earned')).toBeDefined()
  })

  it('shows empty state when no achievements earned', () => {
    mockUseAchievements.mockReturnValue({
      earnedAchievements: [],
      totalCount: 10,
      earnedCount: 0,
      loading: false,
    })

    const profile = createMockProfile()

    renderWithProviders(<ProfileScreen />, {
      authContext: {
        profile,
        user: {
          id: profile.id,
          email: 'test@example.com',
          aud: 'authenticated',
          role: 'authenticated',
          email_confirmed_at: new Date().toISOString(),
          phone: null,
          confirmed_at: new Date().toISOString(),
          last_sign_in_at: new Date().toISOString(),
          app_metadata: {},
          user_metadata: {},
          identities: [],
          created_at: new Date().toISOString(),
          updated_at: new Date().toISOString(),
        },
      },
    })

    expect(screen.getByText('No achievements yet')).toBeDefined()
    expect(screen.getByText('Explore, connect, and create posts to earn badges!')).toBeDefined()
  })

  // ---------------------------------------------------------------------------
  // EDIT MODE TESTS
  // ---------------------------------------------------------------------------

  it('edit mode toggle works', async () => {
    const profile = createMockProfile({
      display_name: 'Test User',
    })

    renderWithProviders(<ProfileScreen />, {
      authContext: {
        profile,
        user: {
          id: profile.id,
          email: 'test@example.com',
          aud: 'authenticated',
          role: 'authenticated',
          email_confirmed_at: new Date().toISOString(),
          phone: null,
          confirmed_at: new Date().toISOString(),
          last_sign_in_at: new Date().toISOString(),
          app_metadata: {},
          user_metadata: {},
          identities: [],
          created_at: new Date().toISOString(),
          updated_at: new Date().toISOString(),
        },
      },
    })

    // Click edit button
    const editButton = screen.getByTestId('profile-edit-name-button')
    fireEvent.press(editButton)

    // Should show input and save/cancel buttons
    await waitFor(() => {
      expect(screen.getByTestId('profile-display-name-input')).toBeDefined()
      expect(screen.getByTestId('profile-save-button')).toBeDefined()
      expect(screen.getByTestId('profile-cancel-edit-button')).toBeDefined()
    })
  })

  it('cancel button exits edit mode', async () => {
    const profile = createMockProfile({
      display_name: 'Original Name',
    })

    renderWithProviders(<ProfileScreen />, {
      authContext: {
        profile,
        user: {
          id: profile.id,
          email: 'test@example.com',
          aud: 'authenticated',
          role: 'authenticated',
          email_confirmed_at: new Date().toISOString(),
          phone: null,
          confirmed_at: new Date().toISOString(),
          last_sign_in_at: new Date().toISOString(),
          app_metadata: {},
          user_metadata: {},
          identities: [],
          created_at: new Date().toISOString(),
          updated_at: new Date().toISOString(),
        },
      },
    })

    // Enter edit mode
    fireEvent.press(screen.getByTestId('profile-edit-name-button'))

    // Change input
    const input = screen.getByTestId('profile-display-name-input')
    fireEvent.changeText(input, 'New Name')

    // Click cancel
    fireEvent.press(screen.getByTestId('profile-cancel-edit-button'))

    // Should exit edit mode and restore original value
    await waitFor(() => {
      expect(screen.queryByTestId('profile-display-name-input')).toBeNull()
      expect(screen.getByText('Original Name')).toBeDefined()
    })
  })

  it('save button calls updateProfile', async () => {
    const mockUpdateProfile = vi.fn().mockResolvedValue({ error: null })
    const profile = createMockProfile({
      display_name: 'Old Name',
    })

    renderWithProviders(<ProfileScreen />, {
      authContext: {
        profile,
        user: {
          id: profile.id,
          email: 'test@example.com',
          aud: 'authenticated',
          role: 'authenticated',
          email_confirmed_at: new Date().toISOString(),
          phone: null,
          confirmed_at: new Date().toISOString(),
          last_sign_in_at: new Date().toISOString(),
          app_metadata: {},
          user_metadata: {},
          identities: [],
          created_at: new Date().toISOString(),
          updated_at: new Date().toISOString(),
        },
        updateProfile: mockUpdateProfile,
      },
    })

    // Enter edit mode
    fireEvent.press(screen.getByTestId('profile-edit-name-button'))

    // Change name
    const input = screen.getByTestId('profile-display-name-input')
    fireEvent.changeText(input, 'New Name')

    // Save
    fireEvent.press(screen.getByTestId('profile-save-button'))

    await waitFor(() => {
      expect(mockUpdateProfile).toHaveBeenCalledWith({
        display_name: 'New Name',
      })
    })
  })

  it('shows error when display name is too long', async () => {
    const profile = createMockProfile()

    renderWithProviders(<ProfileScreen />, {
      authContext: {
        profile,
        user: {
          id: profile.id,
          email: 'test@example.com',
          aud: 'authenticated',
          role: 'authenticated',
          email_confirmed_at: new Date().toISOString(),
          phone: null,
          confirmed_at: new Date().toISOString(),
          last_sign_in_at: new Date().toISOString(),
          app_metadata: {},
          user_metadata: {},
          identities: [],
          created_at: new Date().toISOString(),
          updated_at: new Date().toISOString(),
        },
      },
    })

    // Enter edit mode
    fireEvent.press(screen.getByTestId('profile-edit-name-button'))

    // Enter too long name
    const input = screen.getByTestId('profile-display-name-input')
    fireEvent.changeText(input, 'a'.repeat(51)) // 51 characters

    // Try to save
    fireEvent.press(screen.getByTestId('profile-save-button'))

    await waitFor(() => {
      expect(screen.getByTestId('profile-display-name-error')).toBeDefined()
      expect(screen.getByText('Display name must be 50 characters or less')).toBeDefined()
    })
  })

  it('shows error banner when updateProfile fails', async () => {
    const mockUpdateProfile = vi.fn().mockResolvedValue({
      error: { message: 'Update failed' },
    })
    const profile = createMockProfile()

    renderWithProviders(<ProfileScreen />, {
      authContext: {
        profile,
        user: {
          id: profile.id,
          email: 'test@example.com',
          aud: 'authenticated',
          role: 'authenticated',
          email_confirmed_at: new Date().toISOString(),
          phone: null,
          confirmed_at: new Date().toISOString(),
          last_sign_in_at: new Date().toISOString(),
          app_metadata: {},
          user_metadata: {},
          identities: [],
          created_at: new Date().toISOString(),
          updated_at: new Date().toISOString(),
        },
        updateProfile: mockUpdateProfile,
      },
    })

    // Enter edit mode and save
    fireEvent.press(screen.getByTestId('profile-edit-name-button'))
    fireEvent.press(screen.getByTestId('profile-save-button'))

    await waitFor(() => {
      expect(screen.getByTestId('profile-error-banner')).toBeDefined()
      expect(screen.getByText('Update failed')).toBeDefined()
    })
  })

  // ---------------------------------------------------------------------------
  // NAVIGATION TESTS
  // ---------------------------------------------------------------------------

  it('navigation to settings works', () => {
    const profile = createMockProfile()

    renderWithProviders(<ProfileScreen />, {
      authContext: {
        profile,
        user: {
          id: profile.id,
          email: 'test@example.com',
          aud: 'authenticated',
          role: 'authenticated',
          email_confirmed_at: new Date().toISOString(),
          phone: null,
          confirmed_at: new Date().toISOString(),
          last_sign_in_at: new Date().toISOString(),
          app_metadata: {},
          user_metadata: {},
          identities: [],
          created_at: new Date().toISOString(),
          updated_at: new Date().toISOString(),
        },
      },
    })

    const settingsButton = screen.getByTestId('profile-settings-button')
    fireEvent.press(settingsButton)

    expect(mockNavigate).toHaveBeenCalledWith('Settings')
  })

  it('navigates to avatar creator when edit avatar is pressed', () => {
    const profile = createMockProfile()

    renderWithProviders(<ProfileScreen />, {
      authContext: {
        profile,
        user: {
          id: profile.id,
          email: 'test@example.com',
          aud: 'authenticated',
          role: 'authenticated',
          email_confirmed_at: new Date().toISOString(),
          phone: null,
          confirmed_at: new Date().toISOString(),
          last_sign_in_at: new Date().toISOString(),
          app_metadata: {},
          user_metadata: {},
          identities: [],
          created_at: new Date().toISOString(),
          updated_at: new Date().toISOString(),
        },
      },
    })

    const editAvatarButton = screen.getByTestId('profile-edit-avatar-button')
    fireEvent.press(editAvatarButton)

    expect(mockNavigate).toHaveBeenCalledWith('AvatarCreator', { mode: 'self' })
  })

  // ---------------------------------------------------------------------------
  // VERIFICATION TESTS
  // ---------------------------------------------------------------------------

  it('shows verification prompt for non-verified users', () => {
    const profile = createMockProfile({
      is_verified: false,
    })

    renderWithProviders(<ProfileScreen />, {
      authContext: {
        profile,
        user: {
          id: profile.id,
          email: 'test@example.com',
          aud: 'authenticated',
          role: 'authenticated',
          email_confirmed_at: new Date().toISOString(),
          phone: null,
          confirmed_at: new Date().toISOString(),
          last_sign_in_at: new Date().toISOString(),
          app_metadata: {},
          user_metadata: {},
          identities: [],
          created_at: new Date().toISOString(),
          updated_at: new Date().toISOString(),
        },
      },
    })

    expect(screen.getByTestId('profile-verification-prompt')).toBeDefined()
    expect(screen.getByText('Get Verified')).toBeDefined()
  })

  it('does not show verification prompt for verified users', () => {
    const profile = createMockProfile({
      is_verified: true,
      verified_at: new Date().toISOString(),
    })

    renderWithProviders(<ProfileScreen />, {
      authContext: {
        profile,
        user: {
          id: profile.id,
          email: 'test@example.com',
          aud: 'authenticated',
          role: 'authenticated',
          email_confirmed_at: new Date().toISOString(),
          phone: null,
          confirmed_at: new Date().toISOString(),
          last_sign_in_at: new Date().toISOString(),
          app_metadata: {},
          user_metadata: {},
          identities: [],
          created_at: new Date().toISOString(),
          updated_at: new Date().toISOString(),
        },
      },
    })

    expect(screen.queryByTestId('profile-verification-prompt')).toBeNull()
  })
})
