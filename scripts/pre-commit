#!/bin/bash
#
# Pre-commit hook to prevent committing secrets
# ==============================================
#
# This hook scans staged files for common API key patterns
# and blocks the commit if any are found.
#

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Patterns that indicate secrets (regex)
# These patterns match common API key formats
SECRET_PATTERNS=(
    'AIza[0-9A-Za-z_-]{35}'                    # Google API keys
    'sk-[a-zA-Z0-9]{20,}'                      # OpenAI/Stripe secret keys
    'pk_live_[a-zA-Z0-9]+'                     # Stripe publishable keys (live)
    'sk_live_[a-zA-Z0-9]+'                     # Stripe secret keys (live)
    'ghp_[a-zA-Z0-9]{36}'                      # GitHub personal access tokens
    'github_pat_[a-zA-Z0-9]{22}_[a-zA-Z0-9]+' # GitHub fine-grained PATs
    'xox[baprs]-[0-9]{10,13}-[a-zA-Z0-9-]+'   # Slack tokens
    'eyJ[a-zA-Z0-9_-]*\.eyJ[a-zA-Z0-9_-]*\.'  # JWT tokens
    'AKIA[0-9A-Z]{16}'                         # AWS access keys
    'supabase.*anon.*key'                      # Supabase anon key mentions
    'sb[a-z]_[a-zA-Z0-9]{20,}'                # Supabase keys (underscore format)
    'sb[a-z]-[a-zA-Z0-9]{20,}'                # Supabase keys (hyphen format)
    '"keystorePassword"'                       # Android keystore passwords in JSON
    '"keyPassword"'                            # Android key passwords in JSON
    'SSH_PASSWORD='                            # SSH passwords in env vars
    'MAC_SSH_PASSWORD='                        # Mac SSH passwords
    'SUPABASE_SECRET_KEY='                     # Supabase secret key assignment
    'SUPABASE_DATABASE_PW='                    # Supabase database password
    'DATABASE_PW='                             # Generic database password
    'PRIVATE_KEY='                             # Private key assignments
)

# Files that should NEVER be committed (block the entire file)
BLOCKED_FILES=(
    '.env'
    '.env.local'
    '.env.production'
    '.env.staging'
    'credentials.json'
    '*.keystore'
    '*.jks'
    '*.p12'
    '*.pem'
    'id_rsa'
    'id_ed25519'
)

# Files/patterns to always skip
SKIP_PATTERNS=(
    '\.git/'
    'node_modules/'
    'package-lock\.json'
    '\.env\.example'
    'CLAUDE\.md'          # Allow documentation about key patterns
    '\.git/hooks/'        # Don't scan this hook itself
)

# Build skip pattern regex
SKIP_REGEX=$(IFS='|'; echo "${SKIP_PATTERNS[*]}")

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

FOUND_SECRETS=0
PROBLEM_FILES=""

# First pass: Check for blocked files that should never be committed
for FILE in $STAGED_FILES; do
    BASENAME=$(basename "$FILE")
    for BLOCKED in "${BLOCKED_FILES[@]}"; do
        # Support glob patterns (*.keystore) and exact matches (.env)
        if [[ "$BASENAME" == $BLOCKED ]] || [[ "$FILE" == $BLOCKED ]]; then
            FOUND_SECRETS=1
            PROBLEM_FILES="$PROBLEM_FILES\n  - $FILE (BLOCKED FILE: should never be committed)"
        fi
    done
done

# Second pass: Scan file content for secret patterns
for FILE in $STAGED_FILES; do
    # Skip files matching skip patterns
    if echo "$FILE" | grep -qE "$SKIP_REGEX"; then
        continue
    fi

    # Skip binary files
    if file "$FILE" 2>/dev/null | grep -q "binary"; then
        continue
    fi

    # Check if file exists
    if [ ! -f "$FILE" ]; then
        continue
    fi

    # Scan for each secret pattern
    for PATTERN in "${SECRET_PATTERNS[@]}"; do
        # Get the staged content of the file
        MATCHES=$(git diff --cached "$FILE" 2>/dev/null | grep -E "^\+" | grep -oE "$PATTERN" 2>/dev/null)
        if [ -n "$MATCHES" ]; then
            FOUND_SECRETS=1
            PROBLEM_FILES="$PROBLEM_FILES\n  - $FILE (pattern: ${PATTERN:0:20}...)"
            break
        fi
    done
done

if [ $FOUND_SECRETS -eq 1 ]; then
    echo -e "${RED}========================================${NC}"
    echo -e "${RED}  COMMIT BLOCKED: Potential secrets detected!${NC}"
    echo -e "${RED}========================================${NC}"
    echo ""
    echo -e "${YELLOW}The following files contain patterns that look like API keys or secrets:${NC}"
    echo -e "$PROBLEM_FILES"
    echo ""
    echo "Actions to take:"
    echo "  1. Remove the secrets from the files"
    echo "  2. Use environment variables instead (process.env.YOUR_VAR)"
    echo "  3. Add files to .gitignore if they should never be committed"
    echo ""
    echo "If this is a false positive, you can bypass with:"
    echo "  git commit --no-verify"
    echo ""
    echo -e "${RED}Remember: Once a secret is in git history, it's compromised forever.${NC}"
    exit 1
fi

exit 0
