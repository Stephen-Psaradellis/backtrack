{
  "name": "backtrack",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry.js",
  "expo": {
    "install": {
      "exclude": []
    }
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest --config vitest.e2e.config.js",
    "test:unit": "vitest run",
    "test:components": "vitest",
    "typecheck": "tsc --noEmit",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "e2e": "maestro test .maestro/flows/",
    "e2e:auth": "maestro test .maestro/flows/auth/",
    "e2e:navigation": "maestro test .maestro/flows/navigation/",
    "e2e:home": "maestro test .maestro/flows/home/",
    "e2e:posts": "maestro test .maestro/flows/posts/",
    "e2e:avatar": "maestro test .maestro/flows/avatar/",
    "e2e:chat": "maestro test .maestro/flows/chat/",
    "e2e:profile": "maestro test .maestro/flows/profile/",
    "e2e:record": "maestro record",
    "seed": "npx ts-node scripts/seed-test-data.ts",
    "prepare": "node -e \"const fs=require('fs'),p=require('path');const s=p.join('scripts','pre-commit'),d=p.join('.git','hooks','pre-commit');if(fs.existsSync(s)){fs.copyFileSync(s,d);try{fs.chmodSync(d,0o755)}catch(e){}}\""
  },
  "dependencies": {
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "~11.4.1",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.2.0",
    "@sentry/react-native": "~7.2.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10",
    "@tanstack/react-query": "^5.90.21",
    "@vis.gl/react-google-maps": "^1.4.2",
    "base64-arraybuffer": "^1.0.2",
    "date-fns": "^4.1.0",
    "expo": "~54.0.31",
    "expo-auth-session": "^7.0.10",
    "expo-build-properties": "^1.0.10",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.12",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-navigation-bar": "^5.0.10",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "^15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.8",
    "graphql": "^16.9.0",
    "graphql-request": "^7.1.2",
    "lucide-react": "^0.562.0",
    "lucide-react-native": "^0.562.0",
    "next": "15.5.9",
    "posthog-react-native": "^4.17.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~3.17.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-view-shot": "^4.0.3",
    "react-native-walkthrough-tooltip": "^1.6.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@eslint/eslintrc": "^3",
    "@expo/ngrok": "^4.1.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.1.0",
    "@testing-library/react-native": "^12.4.3",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "@vitest/coverage-v8": "^4.0.16",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^9",
    "eslint-config-next": "15.5.9",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.0.16"
  },
  "overrides": {
    "react-test-renderer": "19.1.0",
    "react-shallow-renderer": {
      "react": "$react"
    }
  },
  "workspaces": [
    "packages/*"
  ]
}
